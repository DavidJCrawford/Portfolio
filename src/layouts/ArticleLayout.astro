---
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';
import { withBase } from '../lib/url';
import type { CollectionEntry } from 'astro:content';

interface Props { entry: CollectionEntry<'articles'> }
const { entry } = Astro.props;
const { title, dek, date, readingTime, canonicalUrl } = entry.data;
const iso = new Date(date).toISOString();
const human = new Date(date).toLocaleDateString('en-NZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const url = new URL(Astro.url.pathname, Astro.site).href;
const home = new URL(import.meta.env.BASE_URL, Astro.site).href;
const schema = [
  {
    '@type': 'BlogPosting',
    '@id': `${url}#article`,
    headline: title,
    description: dek,
    datePublished: iso,
    dateModified: iso,
    url,
    mainEntityOfPage: url,
    author: { '@id': `${home}#person` },
    publisher: { '@id': `${home}#person` },
    isPartOf: { '@id': `${home}#website` },
    inLanguage: 'en',
  },
];
---

<BaseLayout title={title} description={dek} canonicalUrl={canonicalUrl} ogType="article" schema={schema}>
  <article class="article">
    <div class="shell">
      <header class="masthead measure">
        <p class="eyebrow">Article</p>
        <h1 class="title">{title}</h1>
        <p class="dek">{dek}</p>
        <p class="meta">
          <time datetime={iso}>{human}</time>
          {readingTime && <><span class="dot" aria-hidden="true">·</span><span>{readingTime}</span></>}
        </p>
      </header>

      <hr class="hairline rule" />

      <Prose>
        <slot />
      </Prose>

      <footer class="endnote measure">
        <a class="unstyled back" href={withBase('#exhibition')}>← Back to the exhibition</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .article { padding-block: clamp(var(--space-6), 4vw, var(--space-8)); }
  .masthead { margin-inline: auto; }
  .title { margin-top: var(--space-3); }
  .dek {
    font-size: var(--fs-dek);
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.4;
    margin-top: var(--space-3);
    max-width: 48ch;
  }
  .meta {
    margin-top: var(--space-4);
    font-family: var(--mono);
    font-size: var(--fs-label);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    display: flex;
    gap: var(--space-2);
  }
  .dot { color: var(--rule-strong); }
  .rule { margin-block: var(--space-5); max-width: var(--measure); margin-inline: auto; }
  .endnote { margin-inline: auto; margin-top: var(--space-7); }
  .back {
    font-family: var(--mono);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    transition: color var(--dur) var(--ease);
  }
  .back:hover { color: var(--accent); }
</style>
